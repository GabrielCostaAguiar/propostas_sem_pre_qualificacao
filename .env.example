# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA versione o arquivo .env.

# ── Microsoft 365 / OneDrive ───────────────────────────────────────────────
# Opcional: ID do tenant da organização (ex: cecad365.onmicrosoft.com ou GUID).
# Se não preenchido, o programa tenta autenticar em qualquer conta corporativa.
AZURE_TENANT_ID=seu_tenant_id_aqui

# ── Gmail (para envio de e-mail via Gmail API) ────────────────────────────
# Conta Gmail que envia o e-mail (deve ser a mesma autorizada no json.json).
GMAIL_EMAIL=dcgce.seplag@gmail.com

# E-mail que receberá as notificações.
EMAIL_DESTINO=dcgce@casacivil.mg.gov.br

# OBS: não é necessária senha. A autenticação usa o arquivo json.json (OAuth2),
# o mesmo utilizado no script R com gm_auth_configure().
# O json.json deve ficar na pasta pai do projeto (fora do controle de versão).
